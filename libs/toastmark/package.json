  "description": "ToastMark - Incremental markdown parser extended from CommonMark.js",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "test:types": "tsc",
    "test": "vitest --config vitest.config.ts",
    "test:ci": "vitest run --config vitest.config.ts",
