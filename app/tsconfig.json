{
  "extends": "../tsconfig.json",
  "include": ["src/**/*.ts", "src/**/*.js", "types/**/*", "../types/**/*"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node", "vitest/globals"],
    "paths": {
      "@/*": ["src/*"],
      "@t/*": ["types/*"]
    },
    "lib": ["esnext", "dom", "dom.iterable"]
  }
}
